            "p:direct/P13750": "14221",
            "schema:description": [
                {
                    "@language": "cy",
                    "@value": "mausoleum yn India"
                },
                {
                    "@language": "es",
                    "@value": "complejo de edificios construido entre 1631 y 1654 en la ciudad de Agra, India y una de las 7 maravillas del mundo moderno"
                },
                {
                    "@language": "zh",
                    "@value": "今位于印度的莫卧儿王朝建筑"
                },
                {
                    "@language": "vi",
                    "@value": "lăng mộ bằng đá cẩm thạch màu trắng ngà ở Ấn Độ"
                },
                {
                    "@language": "tr",
                    "@value": "Hindistan'ın Agra kenti'ndeki anıt mezar"
                },
                {
                    "@language": "tok",
                    "@value": "tomo li lon ma Palata"
                },
                {
                    "@language": "th",
                    "@value": "อาคารฝังศพสร้างด้วยหินอ่อนในอาครา ประเทศอินเดีย"
                },
                {
                    "@language": "te",
                    "@value": "భారత దేశంలోని ఆగ్రా లో ఒక అత్యద్భుతం"
                },
                {
                    "@language": "ta",
                    "@value": "ஏழு உலக அதிசயங்களுள் ஒன்று"
                },
                {
                    "@language": "syl",
                    "@value": "ꠄꠘ꠆ꠒꠤꠀꠞ ꠀꠉ꠆ꠞꠣꠔ ꠙꠞ꠆ꠍꠦ"
                },
                {
                    "@language": "sv",
                    "@value": "mausoleum i Indien"
                },
                {
                    "@language": "su",
                    "@value": "masjid ti India"
                },
                {
                    "@language": "sr",
                    "@value": "мраморни маузолеј у Агри, Индија"
                },
                {
                    "@language": "ru",
                    "@value": "мавзолей-мечеть в Агре, Индия"
                },
                {
                    "@language": "pt",
                    "@value": "mausoléu de mármore em Agra, Índia"
                },
                {
                    "@language": "ps",
                    "@value": "د هند په اگره ښار کې يو مړيستون او ليدنځی"
                },
                {
                    "@language": "pl",
                    "@value": "mauzoleum (Agra, Indie)"
                },
                {
                    "@language": "pa",
                    "@value": "ਪਿਆਰ ਦੀ ਨਿਸ਼ਾਨੀ"
                },
                {
                    "@language": "or",
                    "@value": "ଆଗ୍ରା, ଉତ୍ତରପ୍ରଦେଶ"
                },
                {
                    "@language": "nqo",
                    "@value": "ߌ߲ߘߌ߫ ߘߐ߬ߝߐ ߓߏ߲ ߘߏ߫ ߎߕߊߙ ߔߙߊߘߍߛ߭ ߞߊ߬ߝߏ ߞߣߐ߫߸ ߣߴߊ߬ ߟߐ߬ ߘߊ߫ ߡߜ߭ߏߟ ߝߊ߰ߡߊ߫ ߛߊ ߖߊ߬ߤߊ ߓߟߏ߫ ߓߍߟߍ߲ߘߊ ߘߴߊ߬ ߡߏ߬ߛߏ ߓߊ߲߬ߘߊ߬ߣߍ߲ ߛߊ߬ߣߍ߲ ߛߌ߲ߞߐ߲ ߘߌ߫"
                },
                {
                    "@language": "ne",
                    "@value": "ताज महल भारतको आगरा शहरमा स्थित एक समाधिस्थल हो । यसको निर्माण मुगल सम्राट शाहजहाँले, आफ्नो स्वास्नी मुमताज महलको सम्झनामा गराए ।"
                },
                {
                    "@language": "my",
                    "@value": "အိန္ဒိယနိုင်ငံ၊ အာဂရာမြို့ရှိ စကျင်ကျောက် ဂူဗိမာန်"
                },
                {
                    "@language": "mt",
                    "@value": "mawżolew tal-irħam f’Agra, l-Indja"
                },
                {
                    "@language": "mr",
                    "@value": "जगातील १ आश्र्चर्य"
                },
                {
                    "@language": "mai",
                    "@value": "भारतक आगरा सहरमे स्थित एक समाधिस्थल"
                },
                {
                    "@language": "ks",
                    "@value": "سَفید سَنٛگہِ مَر مَر قَبَر"
                },
                {
                    "@language": "ko",
                    "@value": "무굴 제국의 대표적 건축물"
                },
                {
                    "@language": "kge",
                    "@value": "Kuburan miwah di India"
                },
                {
                    "@language": "ja",
                    "@value": "インド北部アーグラにある墓廟"
                },
                {
                    "@language": "is",
                    "@value": "leghöll á Indlandi"
                },
                {
                    "@language": "inh",
                    "@value": "къубба-маьждиг"
                },
                {
                    "@language": "ilo",
                    "@value": "marmol a mausoleo idiay India"
                },
                {
                    "@language": "hi",
                    "@value": "आगरा में स्थित भारत का सुप्रसिद्ध पर्यटक स्थल"
                },
                {
                    "@language": "he",
                    "@value": "מבנה מונומנטלי בהודו"
                },
                {
                    "@language": "gu",
                    "@value": "આગ્રા, ભારતમાં આવેલ પ્રસિદ્ધ કબર, સાત અજાયબીમાંની એક"
                },
                {
                    "@language": "gpe",
                    "@value": "marble mausoleum insyd Agra, India"
                },
                {
                    "@language": "gl",
                    "@value": "mausoleo de mármore branco construído entre 1632 e 1652"
                },
                {
                    "@language": "fr",
                    "@value": "mausolée de marbre à Agra, État de l'Uttar Pradesh, Inde"
                },
                {
                    "@language": "fa",
                    "@value": "آرامگاهی در نزدیکی شهر آگرا در هند"
                },
                {
                    "@language": "eo",
                    "@value": "maŭzoleo en Barato"
                },
                {
                    "@language": "en-gb",
                    "@value": "Indian mausoleum"
                },
                {
                    "@language": "en",
                    "@value": "marble mausoleum in Agra, India"
                },
                {
                    "@language": "el",
                    "@value": "Μαυσωλείο στην Ινδία"
                },
                {
